<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="using:HaloCreek.Behaviors"
             xmlns:model="using:HaloCreek.Models"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             x:DataType="vm:PromptEditorViewModel"
             x:Class="HaloCreek.Views.Tabs.PromptEditorView">
    <Grid RowDefinitions="*,Auto,Auto"
          Margin="20"
          RowSpacing="16">
        <TextBox Grid.Row="0"
                 AcceptsReturn="True"
                 behaviors:TextBoxDropPathBehavior.AppendFirstPath="True"
                 Text="{Binding PromptText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 TextWrapping="Wrap"
                 PlaceholderText="Type a prompt or drop files here"
                 VerticalContentAlignment="Top">
            <TextBox.KeyBindings>
                <KeyBinding Gesture="Ctrl+Enter"
                            Command="{Binding LaunchCommand}"/>
            </TextBox.KeyBindings>
        </TextBox>

        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto"
              RowSpacing="8">
            <TextBlock Grid.Row="0"
                       Text="Ongoing Sessions"
                       Foreground="#475569"
                       FontSize="12"
                       FontWeight="SemiBold"/>

            <Border Grid.Row="1"
                    MinHeight="62"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FFFFFF"
                    ClipToBounds="True">
                <Grid>
                    <ListBox x:Name="OngoingSessionsList"
                             ItemsSource="{Binding OngoingSessions}"
                             SelectedItem="{Binding SelectedOngoingSession, Mode=TwoWay}"
                             SelectionMode="Single"
                             IsVisible="{Binding HasOngoingSessions}"
                             DoubleTapped="OngoingSessionsList_OnDoubleTapped"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="8"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="MinWidth" Value="220"/>
                                <Setter Property="Height" Value="44"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="model:OngoingSessionInfo"
                                          x:CompileBindings="False">
                                <Border BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="#FFFFFF"
                                        Padding="10,6">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10"
                                          Background="Transparent"
                                          VerticalAlignment="Center">
                                        <StackPanel Grid.Column="0"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#0F172A"
                                                       FontSize="13"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding State}"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="Exit"
                                                MinWidth="56"
                                                Height="30"
                                                VerticalAlignment="Center"
                                                Command="{Binding DataContext.ExitSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="No ongoing sessions"
                               IsVisible="{Binding IsOngoingSessionsEmpty}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#64748B"/>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button Content="SendToFront"
                    Command="{Binding SendToFrontCommand}"/>
            <Button Content="Launch"
                    Command="{Binding LaunchCommand}"/>
        </StackPanel>
    </Grid>
</UserControl>
