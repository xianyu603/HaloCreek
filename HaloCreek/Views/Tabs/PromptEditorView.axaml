<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="using:HaloCreek.Views.Components"
             xmlns:model="using:HaloCreek.Models"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             x:DataType="vm:PromptEditorViewModel"
             x:Class="HaloCreek.Views.Tabs.PromptEditorView">
    <Grid RowDefinitions="*,Auto"
          Margin="20"
          RowSpacing="16">
        <Border Grid.Row="0"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Background="#FFFFFF"
                ClipToBounds="True">
            <components:PromptInputView DataContext="{Binding PromptInput}"/>
        </Border>

        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto"
              RowSpacing="8">
            <TextBlock Grid.Row="0"
                       Text="Ongoing Sessions"
                       Foreground="#475569"
                       FontSize="12"
                       FontWeight="SemiBold"/>

            <Border Grid.Row="1"
                    MinHeight="62"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FFFFFF"
                    ClipToBounds="True">
                <Grid>
                    <ListBox x:Name="OngoingSessionsList"
                             ItemsSource="{Binding OngoingSessions}"
                             SelectedItem="{Binding SelectedOngoingSession, Mode=TwoWay}"
                             SelectionMode="Single"
                             IsVisible="{Binding HasOngoingSessions}"
                             DoubleTapped="OngoingSessionsList_OnDoubleTapped"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="8"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             ScrollViewer.VerticalScrollBarVisibility="Disabled">
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,8,0"/>
                                <Setter Property="MinWidth" Value="236"/>
                                <Setter Property="Height" Value="58"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            </Style>
                            <Style Selector="Button.sessionActionButton">
                                <Setter Property="Width" Value="24"/>
                                <Setter Property="Height" Value="22"/>
                                <Setter Property="MinWidth" Value="24"/>
                                <Setter Property="MinHeight" Value="22"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Background" Value="#F8FAFC"/>
                                <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="Foreground" Value="#334155"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="model:OngoingSessionInfo"
                                          x:CompileBindings="False">
                                <Border BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Background="#FFFFFF"
                                        Padding="10,5">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="10"
                                          Background="Transparent"
                                          VerticalAlignment="Center">
                                        <StackPanel Grid.Column="0"
                                                    Spacing="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#0F172A"
                                                       FontSize="13"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding State}"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    Spacing="4"
                                                    VerticalAlignment="Center">
                                            <Button Classes="sessionActionButton"
                                                    ToolTip.Tip="CLI"
                                                    Command="{Binding DataContext.OpenCliCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Width="8"
                                                          Height="8"
                                                          Data="M19,3 L5,3 C3.9,3 3,3.9 3,5 L3,19 C3,20.1 3.9,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.9 20.1,3 19,3 Z M19,19 L5,19 L5,5 L19,5 Z"/>
                                            </Button>
                                            <Button Classes="sessionActionButton"
                                                    ToolTip.Tip="Exit"
                                                    Command="{Binding DataContext.ExitSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}">
                                                <PathIcon Width="8"
                                                          Height="8"
                                                          Data="M18.3,5.71 L12,12 L5.7,5.71 L4.29,7.12 L10.59,13.41 L4.29,19.71 L5.7,21.12 L12,14.83 L18.3,21.12 L19.71,19.71 L13.41,13.41 L19.71,7.12 Z"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <TextBlock Text="No ongoing sessions"
                               IsVisible="{Binding IsOngoingSessionsEmpty}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#64748B"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
