<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="using:HaloCreek.Views.Components"
             xmlns:model="using:HaloCreek.Models"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             x:DataType="vm:PromptEditorViewModel"
             x:Class="HaloCreek.Views.Tabs.PromptEditorView">
    <Grid RowDefinitions="*,Auto"
          Margin="20"
          RowSpacing="16">
        <Border Grid.Row="0"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Background="#FFFFFF"
                ClipToBounds="True">
            <components:PromptInputView DataContext="{Binding PromptInput}"/>
        </Border>

        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto"
              RowSpacing="8">
            <TextBlock Grid.Row="0"
                       Text="Ongoing Sessions"
                       Foreground="#475569"
                       FontSize="12"
                       FontWeight="SemiBold"/>

            <Border Grid.Row="1"
                    MinHeight="80"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#FFFFFF"
                    ClipToBounds="True">
                <Grid>
                    <ScrollViewer IsVisible="{Binding HasOngoingSessions}"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled"
                                  Padding="8">
                        <ItemsControl x:Name="OngoingSessionsItems"
                                      ItemsSource="{Binding OngoingSessions}"
                                      DoubleTapped="OngoingSessionsItems_OnDoubleTapped">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.Styles>
                                <Style Selector="Button.sessionActionButton">
                                    <Setter Property="Width" Value="24"/>
                                    <Setter Property="Height" Value="22"/>
                                    <Setter Property="MinWidth" Value="24"/>
                                    <Setter Property="MinHeight" Value="22"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                                    <Setter Property="Background" Value="#F8FAFC"/>
                                    <Setter Property="BorderBrush" Value="#CBD5E1"/>
                                    <Setter Property="BorderThickness" Value="1"/>
                                    <Setter Property="Foreground" Value="#334155"/>
                                </Style>
                                <Style Selector="Button.restartActionButton">
                                    <Setter Property="Background" Value="#FFF7ED"/>
                                    <Setter Property="BorderBrush" Value="#FDBA74"/>
                                    <Setter Property="Foreground" Value="#C2410C"/>
                                </Style>
                                <Style Selector="Button.sessionActionButton.keepAliveOtherActionButton">
                                    <Setter Property="Background" Value="#FFFBEB"/>
                                    <Setter Property="BorderBrush" Value="#F59E0B"/>
                                    <Setter Property="Foreground" Value="#B45309"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="model:OngoingSession"
                                              x:CompileBindings="False">
                                    <Border BorderBrush="#CBD5E1"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Background="#FFFFFF"
                                            Padding="10,5"
                                            Margin="0,0,8,0"
                                            MinWidth="236"
                                            Height="62">
                                        <Grid ColumnDefinitions="*,Auto"
                                              ColumnSpacing="10"
                                              Background="Transparent"
                                              VerticalAlignment="Center">
                                            <StackPanel Grid.Column="0"
                                                        Spacing="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}"
                                                           Foreground="#0F172A"
                                                           FontSize="13"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding StatusText}"
                                                           Foreground="#64748B"
                                                           FontSize="12"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1"
                                                        Spacing="4"
                                                        VerticalAlignment="Center">
                                                <Button Classes="sessionActionButton"
                                                        Classes.keepAliveOtherActionButton="{Binding IsKeepAliveOther}"
                                                        ToolTip.Tip="CLI"
                                                        IsVisible="{Binding IsAliveOrUnknown}"
                                                        IsEnabled="{Binding CanOpenCli}"
                                                        Command="{Binding DataContext.OpenCliCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <PathIcon Width="8"
                                                              Height="8"
                                                              Data="M19,3 L5,3 C3.9,3 3,3.9 3,5 L3,19 C3,20.1 3.9,21 5,21 L19,21 C20.1,21 21,20.1 21,19 L21,5 C21,3.9 20.1,3 19,3 Z M19,19 L5,19 L5,5 L19,5 Z"/>
                                                </Button>
                                                <Button Classes="sessionActionButton restartActionButton"
                                                        ToolTip.Tip="Restart"
                                                        IsVisible="{Binding IsDead}"
                                                        IsEnabled="{Binding CanRestart}"
                                                        Command="{Binding DataContext.RestartSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <PathIcon Width="10"
                                                              Height="10"
                                                              Data="M17.7,6.3 C16.2,4.3 13.8,3 11.2,3 C6.7,3 3,6.7 3,11.2 C3,15.7 6.7,19.4 11.2,19.4 C14.7,19.4 17.8,17.2 18.9,13.9 L16.8,13.2 C16,15.6 13.8,17.2 11.2,17.2 C7.9,17.2 5.2,14.5 5.2,11.2 C5.2,7.9 7.9,5.2 11.2,5.2 C13.2,5.2 15,6.2 16.1,7.8 L12.8,7.8 L12.8,10 L20,10 L20,2.8 L17.7,2.8 Z"/>
                                                </Button>
                                                <Button Classes="sessionActionButton"
                                                        ToolTip.Tip="Exit"
                                                        Command="{Binding DataContext.ExitSessionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}">
                                                    <PathIcon Width="8"
                                                              Height="8"
                                                              Data="M18.3,5.71 L12,12 L5.7,5.71 L4.29,7.12 L10.59,13.41 L4.29,19.71 L5.7,21.12 L12,14.83 L18.3,21.12 L19.71,19.71 L13.41,13.41 L19.71,7.12 Z"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <TextBlock Text="No ongoing sessions"
                               IsVisible="{Binding IsOngoingSessionsEmpty}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#64748B"/>
                </Grid>
            </Border>
        </Grid>

    </Grid>
</UserControl>
