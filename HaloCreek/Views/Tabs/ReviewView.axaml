<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:model="using:HaloCreek.Models"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             x:DataType="vm:ReviewViewModel"
             x:Class="HaloCreek.Views.Tabs.ReviewView">
    <UserControl.Styles>
        <Style Selector="Button.reviewBarButton">
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style Selector="Border.reviewBarStatus">
            <Setter Property="MinWidth" Value="116"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style Selector="TextBlock.reviewBarStatusText">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
        </Style>

        <Style Selector="Button.reviewPanelToggleButton">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.reviewPanelTitle">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TextBlock.reviewPanelMeta">
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style Selector="TabControl.reviewInnerTabs">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style Selector="TabItem.reviewInnerTab">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="6,0"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="Height" Value="25"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*"
          Margin="20"
          RowSpacing="12">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="12">
            <Border Grid.Column="0"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#E2E8F0"
                    Padding="8">
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <Border Classes="reviewBarStatus"
                            DoubleTapped="ClipLocateStatus_OnDoubleTapped">
                        <TextBlock Classes="reviewBarStatusText"
                                   Text="{Binding ClipLocateStatusText}"
                                   Foreground="{Binding ClipLocateButtonForeground}"/>
                    </Border>
                    <Border Classes="reviewBarStatus"
                            IsEnabled="{Binding HasFrontSession}"
                            DoubleTapped="FrontSession_OnDoubleTapped">
                        <TextBlock Classes="reviewBarStatusText"
                                   Text="Front Session"
                                   Foreground="{Binding FrontSessionButtonForeground}"/>
                    </Border>
                </ItemsControl>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#E2E8F0"
                    Padding="8">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <Button Classes="reviewBarButton"
                                Content="Send Prompt"
                                Command="{Binding SendPromptCommand}"/>
                        <Button Classes="reviewBarButton"
                                Content="Add Note"/>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <StackPanel Orientation="Horizontal"
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Right"
                        Spacing="8">
                <Button Classes="reviewPanelToggleButton"
                        Content="&lt;"
                        Command="{Binding MoveLeftCommand}"/>
                <Button Classes="reviewPanelToggleButton"
                        Content="&gt;"
                        Command="{Binding MoveRightCommand}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LeftPanelWidth}"/>
                <ColumnDefinition Width="{Binding PanelGapWidth}"/>
                <ColumnDefinition Width="{Binding RightPanelWidth}"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="#FFFFFF"
                    ClipToBounds="True"
                    IsVisible="{Binding IsLeftPanelExpanded}">
                <TabControl Classes="reviewInnerTabs"
                            Margin="0"
                            SelectedIndex="0">
                    <TabItem Classes="reviewInnerTab">
                        <TabItem.Header>
                            <TextBlock Text="Modified"
                                       FontSize="13"/>
                        </TabItem.Header>
                        <Grid Background="White">
                            <Grid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Refresh"
                                              Command="{Binding RefreshCommand}"/>
                                </ContextMenu>
                            </Grid.ContextMenu>
                        </Grid>
                    </TabItem>
                    <TabItem Classes="reviewInnerTab">
                        <TabItem.Header>
                            <TextBlock Text="Unreviewed"
                                       FontSize="13"/>
                        </TabItem.Header>
                        <ListBox ItemsSource="{Binding UnreviewedFiles}"
                                 SelectedItem="{Binding SelectedUnreviewedFile, Mode=TwoWay}"
                                 SelectionMode="Single"
                                 BorderThickness="0"
                                 Background="White"
                                 Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Refresh"
                                              Command="{Binding RefreshCommand}"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="MinHeight" Value="34"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="model:ReviewFilePath"
                                              x:CompileBindings="False">
                                    <Grid MinHeight="34"
                                          RowDefinitions="1,*"
                                          Background="Transparent"
                                          DoubleTapped="UnreviewedFile_OnDoubleTapped">
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Diff Against Reviewed"
                                                          Click="DiffUnreviewedAgainstReviewedMenuItem_OnClick"/>
                                                <MenuItem Header="Mark Reviewed"
                                                          Click="AddReviewedMenuItem_OnClick"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Border Grid.Row="0"
                                                Background="#E2E8F0"/>
                                        <Border Grid.Row="1"
                                                Padding="10,0"
                                                Background="Transparent">
                                            <TextBlock Text="{Binding DisplayPath}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#334155"
                                                       FontSize="13"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                    <TabItem Classes="reviewInnerTab">
                        <TabItem.Header>
                            <TextBlock Text="Reviewed"
                                       FontSize="13"/>
                        </TabItem.Header>
                        <ListBox ItemsSource="{Binding ReviewedFiles}"
                                 SelectedItem="{Binding SelectedReviewedFile, Mode=TwoWay}"
                                 SelectionMode="Single"
                                 BorderThickness="0"
                                 Background="White"
                                 Padding="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Refresh"
                                              Command="{Binding RefreshCommand}"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="MinHeight" Value="34"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="model:ReviewFilePath"
                                              x:CompileBindings="False">
                                    <Grid MinHeight="34"
                                          RowDefinitions="1,*"
                                          Background="Transparent">
                                        <Grid.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="Diff Against Working Tree"
                                                          Click="DiffReviewedAgainstWorkingTreeMenuItem_OnClick"/>
                                                <MenuItem Header="Mark Unreviewed"
                                                          Click="MarkUnreviewedMenuItem_OnClick"/>
                                            </ContextMenu>
                                        </Grid.ContextMenu>
                                        <Border Grid.Row="0"
                                                Background="#E2E8F0"/>
                                        <Border Grid.Row="1"
                                                Padding="10,0"
                                                Background="Transparent">
                                            <TextBlock Text="{Binding DisplayPath}"
                                                       VerticalAlignment="Center"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#334155"
                                                       FontSize="13"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="2"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="3"
                    Background="#FFFFFF"
                    ClipToBounds="True"
                    IsVisible="{Binding IsRightPanelExpanded}">
                <Grid Background="#FFFFFF"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
