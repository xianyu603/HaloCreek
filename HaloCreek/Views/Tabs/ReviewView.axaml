<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             x:DataType="vm:ReviewViewModel"
             x:Class="HaloCreek.Views.Tabs.ReviewView">
    <UserControl.Styles>
        <Style Selector="Button.reviewBarButton">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style Selector="Button.reviewStatusButton">
            <Setter Property="IsHitTestVisible" Value="False"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="*,Auto"
          Margin="20"
          RowSpacing="12">
        <Grid Grid.Row="0"/>

        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="12">
            <Border Grid.Column="0"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#E2E8F0"
                    Padding="8">
                <ItemsControl>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <Button Classes="reviewBarButton reviewStatusButton"
                            Content="Match Success"/>
                    <Button Classes="reviewBarButton reviewStatusButton"
                            Content="Front Session"/>
                </ItemsControl>
            </Border>

            <Border Grid.Column="1"
                    BorderBrush="#CBD5E1"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#E2E8F0"
                    Padding="8">
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled">
                    <ItemsControl>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <Button Classes="reviewBarButton"
                                Content="Send Prompt"/>
                        <Button Classes="reviewBarButton"
                                Content="Add Note"/>
                        <Button Classes="reviewBarButton"
                                Content="Mark Reviewed"/>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
