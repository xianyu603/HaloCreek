<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             xmlns:model="using:HaloCreek.Models"
             x:Name="HistorySessionsRoot"
             x:DataType="vm:HistorySessionsViewModel"
             x:Class="HaloCreek.Views.Tabs.HistorySessionsView">
    <Grid RowDefinitions="Auto,*"
          Margin="20"
          RowSpacing="12">
        <TextBox Grid.Row="0"
                 Height="36"
                 Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="Search initial prompt"/>

        <Border Grid.Row="1"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                ClipToBounds="True">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        MinHeight="38"
                        Background="#F8FAFC"
                        Padding="14,0">
                    <Grid ColumnDefinitions="2.6*,2.1*,156"
                          ColumnSpacing="14">
                        <TextBlock Grid.Column="0"
                                   Text="Initial Prompt"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="Latest Activity"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2"
                                   Text="Actions"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1"
                              IsVisible="{Binding HasSessions}"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Sessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="model:HistorySessionInfo"
                                          x:CompileBindings="False">
                                <Border BorderBrush="#E2E8F0"
                                        BorderThickness="0,1,0,0"
                                        Padding="14,12"
                                        Background="White">
                                    <Grid ColumnDefinitions="2.6*,2.1*,156"
                                          ColumnSpacing="14">
                                        <StackPanel Grid.Column="0"
                                                    Spacing="6">
                                            <TextBlock Text="{Binding InitialPrompt}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#0F172A"
                                                       FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8">
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='Created {0:g}'}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="#64748B"
                                                           FontSize="12"/>
                                                <TextBlock Text="{Binding LastUpdatedAt, StringFormat='Updated {0:g}'}"
                                                           TextWrapping="NoWrap"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="#64748B"
                                                           FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Id}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#94A3B8"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1"
                                                    Spacing="6">
                                            <TextBlock Text="{Binding LastPrompt, StringFormat='Last prompt: {0}'}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#334155"/>
                                            <TextBlock Text="{Binding LastReply, StringFormat='Last reply: {0}'}"
                                                       TextWrapping="Wrap"
                                                       Foreground="#64748B"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Top">
                                            <Button Content="Resume"
                                                    MinWidth="72"
                                                    Command="{Binding #HistorySessionsRoot.DataContext.ResumeCommand}"
                                                    CommandParameter="{Binding}"/>
                                            <Button Content="Reedit"
                                                    MinWidth="72"
                                                    Command="{Binding #HistorySessionsRoot.DataContext.ReeditInitialPromptCommand}"
                                                    CommandParameter="{Binding}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Grid Grid.Row="1"
                      MinHeight="160"
                      Background="#FFFFFF"
                      IsVisible="{Binding IsEmptyStateVisible}">
                    <TextBlock Text="No sessions for current workspace"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#64748B"/>
                </Grid>

                <Grid Grid.Row="1"
                      Background="#FFFFFF"
                      IsVisible="False">
                    <TextBlock Text="Loading sessions..."
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#64748B"/>
                </Grid>

                <Grid Grid.Row="1"
                      Background="#FFFFFF"
                      IsVisible="False">
                    <Border Background="#FEF2F2"
                            BorderBrush="#FCA5A5"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            MaxWidth="460">
                        <TextBlock Text="Could not load session history."
                                   TextWrapping="Wrap"
                                   Foreground="#991B1B"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
