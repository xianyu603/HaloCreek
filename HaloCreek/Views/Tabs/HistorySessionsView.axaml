<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HaloCreek.Views.Tabs.HistorySessionsView">
    <Grid RowDefinitions="Auto,*"
          Margin="20"
          RowSpacing="16">
        <Grid Grid.Row="0"
              ColumnDefinitions="*">
            <TextBox Grid.Column="0"
                     PlaceholderText="Search sessions"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="History session list placeholder"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#64748B"/>
        </Border>
    </Grid>
</UserControl>
