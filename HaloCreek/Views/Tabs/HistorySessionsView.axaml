<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             xmlns:model="using:HaloCreek.Models"
             x:Name="HistorySessionsRoot"
             x:DataType="vm:HistorySessionsViewModel"
             x:Class="HaloCreek.Views.Tabs.HistorySessionsView">
    <Grid RowDefinitions="Auto,*,Auto"
          Margin="20"
          RowSpacing="12">
        <Grid Grid.Row="0"
              ColumnDefinitions="*,Auto,Auto"
              ColumnSpacing="8">
            <TextBox Grid.Column="0"
                     Height="36"
                     Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PlaceholderText="Search initial prompt"/>
            <Button Grid.Column="1"
                    Content="Resume"
                    MinWidth="84"
                    Height="36"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding ResumeCommand}"
                    CommandParameter="{Binding SelectedSession}"/>
            <Button Grid.Column="2"
                    Content="Reedit"
                    MinWidth="84"
                    Height="36"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding ReeditInitialPromptCommand}"
                    CommandParameter="{Binding SelectedSession}"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                ClipToBounds="True">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        MinHeight="38"
                        Background="#F8FAFC"
                        Padding="12,0">
                    <Grid ColumnDefinitions="190,2.3*,2.1*"
                          ColumnSpacing="14">
                        <TextBlock Grid.Column="0"
                                   Text="Time"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="Initial Prompt"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2"
                                   Text="Latest Activity"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Sessions}"
                         SelectedItem="{Binding SelectedSession, Mode=TwoWay}"
                         SelectionMode="Single"
                         BorderThickness="0"
                         Background="White"
                         Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Height" Value="90"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="model:HistorySessionInfo"
                                      x:CompileBindings="False">
                            <Grid Height="90"
                                  RowDefinitions="1,*"
                                  Background="Transparent"
                                  ClipToBounds="True">
                                <Border Grid.Row="0"
                                        Background="#E2E8F0"/>
                                <Border Grid.Row="1"
                                        Padding="12,8"
                                        Background="Transparent">
                                    <Grid ColumnDefinitions="190,2.3*,2.1*"
                                          ColumnSpacing="14"
                                          ClipToBounds="True"
                                          VerticalAlignment="Top">
                                        <StackPanel Grid.Column="0"
                                                    Spacing="6"
                                                    VerticalAlignment="Top">
                                            <TextBlock Text="{Binding CreatedAtLocalText, StringFormat='Created {0}'}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#334155"
                                                       FontSize="12"/>
                                            <TextBlock Text="{Binding LastUpdatedAtLocalText, StringFormat='Updated {0}'}"
                                                       TextWrapping="NoWrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="#64748B"
                                                       FontSize="12"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding InitialPromptText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#334155"
                                                   FontSize="13"
                                                   LineHeight="18"
                                                   MaxHeight="72"
                                                   ClipToBounds="True"
                                                   VerticalAlignment="Top"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding LatestActivityText}"
                                                   TextWrapping="Wrap"
                                                   Foreground="#334155"
                                                   FontSize="13"
                                                   LineHeight="18"
                                                   MaxHeight="72"
                                                   ClipToBounds="True"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <TextBox Grid.Row="2"
                 Height="160"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 Text="{Binding SelectedSessionSummaryText, Mode=OneWay}"
                 PlaceholderText="Select a session to view prompt and reply text"/>
    </Grid>
</UserControl>
