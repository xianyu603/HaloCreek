<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HaloCreek.Views.Tabs.GitView">
    <Grid RowDefinitions="Auto,*"
          Margin="20"
          RowSpacing="16">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,Auto,*"
              ColumnSpacing="8">
            <Button Grid.Column="0"
                    Content="Open Diff"
                    IsEnabled="False"/>
            <Button Grid.Column="1"
                    Content="Commit"
                    IsEnabled="False"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="Git change list placeholder"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#64748B"/>
        </Border>
    </Grid>
</UserControl>
