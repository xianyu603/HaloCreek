<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             x:DataType="vm:GitViewModel"
             x:Class="HaloCreek.Views.Tabs.GitView">
    <Grid RowDefinitions="Auto,*"
          Margin="20"
          RowSpacing="16">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto"
              ColumnSpacing="8">
            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        Spacing="8">
                <Button Content="OpenDiff"
                        MinWidth="84"
                        Height="36"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="False"/>
                <Button Content="Commit"
                        MinWidth="84"
                        Height="36"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="False"/>
                <Button Content="ExploreTo"
                        MinWidth="84"
                        Height="36"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="False"/>
                <Button Content="Open"
                        MinWidth="84"
                        Height="36"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="False"/>
                <Button Content="Edit"
                        MinWidth="84"
                        Height="36"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        IsEnabled="False"/>
            </StackPanel>

            <Button Grid.Column="2"
                    Content="Refresh"
                    MinWidth="84"
                    Height="36"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="Git change list placeholder"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#64748B"/>
        </Border>
    </Grid>
</UserControl>
