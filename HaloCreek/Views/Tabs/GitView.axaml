<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaloCreek.ViewModels.Tabs"
             xmlns:model="using:HaloCreek.Models"
             x:DataType="vm:GitViewModel"
             x:Class="HaloCreek.Views.Tabs.GitView">
    <Grid RowDefinitions="Auto,*"
          Margin="20"
          RowSpacing="16">
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*,Auto,Auto"
              ColumnSpacing="8">
            <ItemsControl Grid.Column="0"
                          ItemsSource="{Binding LeftActionButtons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:GitFileActionButtonViewModel"
                                  x:CompileBindings="False">
                        <Button Content="{Binding Label}"
                                MinWidth="84"
                                Height="36"
                                Margin="0,0,8,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Command="{Binding DataContext.RunActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <ItemsControl Grid.Column="2"
                          ItemsSource="{Binding RightActionButtons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:GitFileActionButtonViewModel"
                                  x:CompileBindings="False">
                        <Button Content="{Binding Label}"
                                MinWidth="84"
                                Height="36"
                                Margin="0,0,8,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Command="{Binding DataContext.RunActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Button Grid.Column="3"
                    Content="Refresh"
                    MinWidth="84"
                    Height="36"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <Border Grid.Row="1"
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6"
                Background="White"
                ClipToBounds="True">
            <Grid RowDefinitions="Auto,*">
                <Border Grid.Row="0"
                        MinHeight="38"
                        Background="#F8FAFC"
                        Padding="12,0">
                    <Grid ColumnDefinitions="100,100,*"
                          ColumnSpacing="14">
                        <TextBlock Grid.Column="0"
                                   Text="Status"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1"
                                   Text="Stage"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2"
                                   Text="Path"
                                   VerticalAlignment="Center"
                                   Foreground="#475569"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <ListBox x:Name="ChangesList"
                         Grid.Row="1"
                         ItemsSource="{Binding Changes}"
                         SelectedItem="{Binding SelectedChange, Mode=TwoWay}"
                         SelectionMode="Single"
                         IsVisible="{Binding HasChanges}"
                         DoubleTapped="ChangesList_OnDoubleTapped"
                         BorderThickness="0"
                         Background="White"
                         Padding="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="MinHeight" Value="40"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="model:GitChangeInfo"
                                      x:CompileBindings="False">
                            <Grid MinHeight="40"
                                  RowDefinitions="1,*"
                                  Background="Transparent">
                                <Border Grid.Row="0"
                                        Background="#E2E8F0"/>
                                <Border Grid.Row="1"
                                        Padding="12,0"
                                        Background="Transparent">
                                    <Grid ColumnDefinitions="100,100,*"
                                          ColumnSpacing="14">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ChangeTypeText}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="#334155"
                                                   FontSize="13"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding StageText}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="#334155"
                                                   FontSize="13"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayPath}"
                                                   VerticalAlignment="Center"
                                                   TextWrapping="NoWrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="#334155"
                                                   FontSize="13"/>
                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Grid Grid.Row="1"
                      MinHeight="160"
                      Background="White"
                      IsVisible="{Binding IsEmptyStateVisible}">
                    <TextBlock Text="{Binding EmptyStateText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap"
                               MaxWidth="520"
                               Foreground="#64748B"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
