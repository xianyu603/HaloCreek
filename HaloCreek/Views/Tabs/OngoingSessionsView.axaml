<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HaloCreek.Views.Tabs.OngoingSessionsView">
    <Grid Margin="20">
        <Border
                BorderBrush="#CBD5E1"
                BorderThickness="1"
                CornerRadius="6">
            <TextBlock Text="Ongoing session list placeholder"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Foreground="#64748B"/>
        </Border>
    </Grid>
</UserControl>
