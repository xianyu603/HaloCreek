<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:HaloCreek.ViewModels.Components"
             x:DataType="vm:SessionStateViewModel"
             x:Class="HaloCreek.Views.Components.SessionStateView">
    <Border Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1, 0, 0, 0">
        <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="6"
                  Margin="14,12,14,10">
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="10">
                    <TextBlock Text="{Binding Title}"
                               Foreground="#0F172A"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="1"
                            Background="#DCFCE7"
                            CornerRadius="5"
                            Padding="8,2"
                            VerticalAlignment="Center">
                        <TextBlock Text="{Binding StateText}"
                                   Foreground="#166534"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
                <TextBlock Grid.Row="1"
                           Text="{Binding StateTimestampText}"
                           Foreground="#64748B"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <Border Grid.Row="1"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,1,0,1">
                <ListBox ItemsSource="{Binding Messages}"
                         SelectionMode="Single"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="16,10,16,0"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,0,0,10"/>
                            <Setter Property="MinHeight" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="vm:SessionStateMessageViewModel">
                            <Border Background="{Binding BackgroundBrush}"
                                    BorderBrush="{Binding BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="10,9"
                                    HorizontalAlignment="Stretch">
                                <Grid RowDefinitions="Auto,Auto"
                                      RowSpacing="6">
                                    <Grid ColumnDefinitions="4,*,Auto"
                                          ColumnSpacing="8">
                                        <Border Background="{Binding AccentBrush}"
                                                CornerRadius="2"
                                                Margin="0,2,0,2"/>
                                        <StackPanel Grid.Column="1"
                                                    Orientation="Horizontal"
                                                    Spacing="7">
                                            <TextBlock Text="{Binding SenderText}"
                                                       Foreground="#0F172A"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding PhaseText}"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding TimestampText}"
                                                   Foreground="#64748B"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Message}"
                                               Foreground="#334155"
                                               FontSize="12"
                                               LineHeight="18"
                                               TextWrapping="Wrap"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="{Binding TokenSummaryText}"
                       Foreground="#475569"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="16"
                       Margin="14,9,14,10"/>
        </Grid>
    </Border>
</UserControl>
