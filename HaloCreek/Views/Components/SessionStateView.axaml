<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="clr-namespace:LiveMarkdown.Avalonia;assembly=LiveMarkdown.Avalonia"
             xmlns:model="using:HaloCreek.Models"
             xmlns:state="using:HaloCreek.Services.SessionState"
             xmlns:views="using:HaloCreek.Views.Components"
             x:DataType="model:OngoingSession"
             x:Class="HaloCreek.Views.Components.SessionStateView">
    <Border Background="#FFFFFF"
            BorderBrush="#E2E8F0"
            BorderThickness="1, 0, 0, 0">
        <Grid RowDefinitions="Auto,*,Auto">
            <Grid Grid.Row="0"
                  RowDefinitions="Auto,Auto"
                  RowSpacing="6"
                  Margin="14,12,14,10">
                <Grid ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="10">
                    <TextBlock Text="{Binding Title}"
                               Foreground="#0F172A"
                               FontSize="14"
                               FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis"/>
                    <Border Grid.Column="1"
                            Background="#DCFCE7"
                            CornerRadius="5"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsAliveOrUnknown}">
                        <TextBlock Text="{Binding ActivityText}"
                                   Foreground="#166534"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Border Grid.Column="2"
                            Background="#DCFCE7"
                            CornerRadius="5"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsAliveOrUnknown}">
                        <TextBlock Text="{Binding TaskStateText}"
                                   Foreground="#166534"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                    <Border Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Background="#FEE2E2"
                            CornerRadius="5"
                            Padding="8,2"
                            VerticalAlignment="Center"
                            IsVisible="{Binding IsDead}">
                        <TextBlock Text="{Binding ActivityText}"
                                   Foreground="#B91C1C"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"/>
                    </Border>
                </Grid>
                <TextBlock Grid.Row="1"
                           Text="{Binding StateTimestampText}"
                           Foreground="#64748B"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"/>
            </Grid>

            <Border Grid.Row="1"
                    BorderBrush="#E2E8F0"
                    BorderThickness="0,1,0,1">
                <ScrollViewer x:Name="MessagesScrollViewer"
                              SizeChanged="MessagesScrollViewer_SizeChanged"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Padding="16,10,20,0">
                    <StackPanel>
                        <ItemsControl x:Name="MessagesItemsControl"
                                      ItemsSource="{Binding Messages}"
                                      HorizontalAlignment="Stretch">
                            <ItemsControl.Styles>
                                <Style Selector="ContentPresenter">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="MinWidth" Value="0"/>
                                </Style>
                            </ItemsControl.Styles>
                            <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="state:SessionMessage">
                                <Border Background="{Binding Sender, Converter={x:Static views:SessionMessageDisplayConverters.BackgroundBrush}}"
                                        BorderBrush="{Binding Sender, Converter={x:Static views:SessionMessageDisplayConverters.BorderBrush}}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="10,9"
                                        Margin="0,0,0,10"
                                        MinWidth="0"
                                        HorizontalAlignment="Stretch">
                                    <Grid RowDefinitions="Auto,Auto"
                                          MinWidth="0"
                                          RowSpacing="6">
                                        <Grid ColumnDefinitions="4,*,Auto"
                                              MinWidth="0"
                                              ColumnSpacing="8">
                                            <Border Background="{Binding Sender, Converter={x:Static views:SessionMessageDisplayConverters.AccentBrush}}"
                                                    CornerRadius="2"
                                                    Margin="0,2,0,2"/>
                                            <StackPanel Grid.Column="1"
                                                        MinWidth="0"
                                                        Orientation="Horizontal"
                                                        Spacing="7">
                                                <TextBlock Text="{Binding Sender, Converter={x:Static views:SessionMessageDisplayConverters.SenderText}}"
                                                           Foreground="#0F172A"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Phase, Converter={x:Static views:SessionMessageDisplayConverters.PhaseText}}"
                                                           Foreground="#64748B"
                                                           FontSize="12"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Timestamp, Converter={x:Static views:SessionMessageDisplayConverters.TimestampText}}"
                                                       Foreground="#64748B"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </Grid>
                                        <md:MarkdownRenderer Grid.Row="1"
                                                             MarkdownBuilder="{Binding Message, Converter={x:Static md:ValueConverters.ToObservableStringBuilder}}"
                                                             LinkCommand="{Binding OpenMarkdownLinkCommand, RelativeSource={RelativeSource AncestorType=views:SessionStateView}}"
                                                             CodeBlockColorTheme="LightPlus"
                                                             AttachedToVisualTree="MarkdownRenderer_AttachedToVisualTree"
                                                             MinWidth="0"
                                                             HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Height="16"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <TextBlock Grid.Row="2"
                       Text="{Binding TokenSummaryText}"
                       Foreground="#475569"
                       FontSize="12"
                       TextWrapping="Wrap"
                       LineHeight="16"
                       Margin="14,9,14,10"/>
        </Grid>
    </Border>
</UserControl>
